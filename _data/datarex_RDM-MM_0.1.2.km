            "followUpUuids": {
              "changed": false
            },
            "label": {
              "changed": true,
              "value": "Legal processes are ad-hoc and reactive, with no standardized framework or templates regarding RDM. Legal tasks are handled informally by various departments. Agreements go through minimal review."
            },
            "metricMeasures": {
              "changed": false
            }
          },
