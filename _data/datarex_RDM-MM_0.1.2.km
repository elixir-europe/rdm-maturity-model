              "changed": false
            },
            "label": {
              "changed": true,
              "value": "Limited or no documented policies/procedures for security of RD; minimal measures are in place, reactive; staff awareness is low; basic antivirus and firewalls."
            },
            "metricMeasures": {
              "changed": false
            }
