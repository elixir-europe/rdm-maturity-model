        },
        {
          "content": {
            "advice": {
              "changed": false
            },
            "annotations": {
              "changed": false
            },
            "eventType": "EditAnswerEvent",
            "followUpUuids": {
              "changed": false
            },
            "label": {
              "changed": true,
              "value": "Standard templates and contractual clauses are being introduced, but not consistently used. The legal department exists but does not yet support project initiation or have fully defined processes for RDM issues."
            },
            "metricMeasures": {
              "changed": false
            }
          },
