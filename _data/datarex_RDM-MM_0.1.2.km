            },
            "eventType": "EditAnswerEvent",
            "followUpUuids": {
              "changed": false
            },
            "label": {
              "changed": true,
              "value": "The legal framework is well-defined and standardized across the organization. A dedicated personelle is responsible for supporting establishment of legal framework covering RDM requirements. Comprehensive templates and standardized contractual clauses for RDM issues."
            },
            "metricMeasures": {
              "changed": false
            }
          },
