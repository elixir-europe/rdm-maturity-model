            "label": {
              "changed": true,
              "value": "1. Ethical considerations for RD are minimal and reactive. There are no formal guidelines or processes for ensuring ethical compliance in research."
            },
            "metricMeasures": {
              "changed": true,
              "value": [
                {
                  "measure": 0.25,
