            "followUpUuids": {
              "changed": false
            },
            "label": {
              "changed": true,
              "value": "Continuously improved and optimized legal framework for research data; regularly updated to reflect RDM best practices and regulatory changes. Use of advanced, customizable templates and optimized contractual clauses for RDM issues."
            },
            "metricMeasures": {
              "changed": false
            }
          },
