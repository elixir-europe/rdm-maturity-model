      "metamodelVersion": 20,
      "name": "Maturity model of research data management ",
      "nonEditable": false,
      "organizationId": "datarex",
      "phase": "ReleasedKnowledgeModelPackagePhase",
      "previousPackageId": "datarex:RDM-MM:0.1.0",
      "readme": "This is DSW representation of results of [DATAREX](https://elixir-europe.org/internal-projects/commissioned-services/datarex) F2F event in Bari 24-26 March 2025.\n\nJust a list of indicators with description and maturity levels  but without links to guidelines.\n\nAuthors in alphabetical order:\nMinna Ahokas\nFederico Bianchini\nKorbinian Bösl\nAlessandro Cestaro\nFlora D'Anna\nVilém Děd\nNazeefa Fatima\nNiclas Jareborg\nMijke Jetten\nLuka Kranjc\nBrane Leskošek\nFlavio Licciulli\nAída Moure Fernández\nIvan Mičetić\nMinna Ahokas\nAnna Niehues\nXenia Perez Sitja\nDiana Pilvar\nGil Poiares-Oliveira\nMarina Popleteeva\nAmir Szitenberg\nJeanne Wilbrandt\n\n",
      "version": "0.1.1"
    },
    {
      "createdAt": "2025-05-14T14:39:37.261797Z",
      "description": "Maturity Model for organization’s RDM services/support (self-evaluation tool)",
      "events": [
        {
          "content": {
            "abbreviation": {
              "changed": false
            },
            "annotations": {
              "changed": false
            },
            "description": {
              "changed": true,
              "value": "The strategy and sustainability domain assesses the maturity and alignment of an organisation's Research Data Management strategy. This evaluates its definition, implementation, and personnel support, alongside communication effectiveness and adherence to policies."
            },
            "eventType": "EditMetricEvent",
            "title": {
              "changed": false
            }
          },
          "createdAt": "2025-05-14T07:51:03Z",
          "entityUuid": "2ec98158-e2b6-428e-bcf4-126ade361b1c",
          "parentUuid": "6a2a7b86-aa85-41a0-8bf3-0feb29732b5c",
          "uuid": "4e137eef-d37d-4367-abd2-dac550a855a1"
        },
        {
          "content": {
            "abbreviation": {
              "changed": false
            },
            "annotations": {
              "changed": false
            },
            "description": {
              "changed": true,
              "value": "The legal and governance domain evaluates the maturity of an organisation’s research data governance and security. This assesses the robustness of its legal framework, IT security measures, and compliance with GDPR and data protection regulations, including the implementation of roles and systems to ensure adherence."
            },
            "eventType": "EditMetricEvent",
            "title": {
              "changed": false
            }
          },
          "createdAt": "2025-05-14T07:51:21Z",
          "entityUuid": "18c62f4b-e853-4499-bad0-b49a6715c4a5",
          "parentUuid": "6a2a7b86-aa85-41a0-8bf3-0feb29732b5c",
          "uuid": "2cd04415-ab4d-4897-b05d-f01cf6cee53c"
        },
        {
          "content": {
            "abbreviation": {
              "changed": false
            },
            "annotations": {
              "changed": false
            },
            "description": {
              "changed": true,
              "value": "RDM support domain assesses the organisation’s approach to Research Data Management (RDM) training, expertise, and communication. This evaluates the structure, accessibility, and visibility of training activities and materials, as well as opportunities for networking at various levels."
            },
            "eventType": "EditMetricEvent",
            "title": {
              "changed": false
            }
          },
          "createdAt": "2025-05-14T07:51:43Z",
          "entityUuid": "71be6293-a566-4044-b443-35f20f1caa19",
          "parentUuid": "6a2a7b86-aa85-41a0-8bf3-0feb29732b5c",
          "uuid": "fe152b23-9313-4764-85b2-7619c1a8cc0c"
        },
        {
          "content": {
            "abbreviation": {
              "changed": false
            },
            "annotations": {
              "changed": false
            },
            "description": {
              "changed": true,
              "value": "Data and metadata domain assesses an organisation's provision and adoption of Research Data Management (RDM) tools, standards, infrastructure, and support systems. This evaluates the maturity and effectiveness of technical resources, documentation standards, accessibility measures, and centralized data management, ensuring alignment with best practices and user adoption."
            },
            "eventType": "EditMetricEvent",
            "title": {
              "changed": false
            }
          },
          "createdAt": "2025-05-14T07:51:53Z",
          "entityUuid": "c5667e37-c29a-497e-a530-0683439fa447",
          "parentUuid": "6a2a7b86-aa85-41a0-8bf3-0feb29732b5c",
          "uuid": "b851ecd5-d355-44e3-bbc3-0b6ab01c8eed"
        },
        {
